---
import Base from '../layouts/Base.astro';
import languagesData from '../../data/languages.json';

const { languages, timeSeries, window, _dummy } = languagesData;

const total = languages.reduce((a, l) => a + l.commits, 0);
const dominant = [...languages].sort((a, b) => b.commits - a.commits)[0];
const fastestGrowing = [...languages]
  .filter(l => l.fileCountGrowth30d > 0 || l.authorsGrowth30d > 0)
  .sort((a, b) =>
    (b.fileCountGrowth30d + b.authorsGrowth30d * 3) -
    (a.fileCountGrowth30d + a.authorsGrowth30d * 3)
  )[0];

const rust = languages.find(l => l.name === 'Rust');
const rustDays = rust ? Math.floor(
  (new Date('2026-04-19') - new Date(rust.firstCommit)) / 86_400_000
) : null;

// Palette (consistent order for stability)
const PALETTE = {
  C:         '#4f94d4',
  Rust:      '#ff7a5c',
  Assembly:  '#8f6ed3',
  'C++':     '#5fa5a5',
  Kconfig:   '#c58b2e',
  Make:      '#d46b8f',
  Markdown:  '#4a9d5f',
  YAML:      '#2b5c8a',
  Shell:     '#6c757d',
  Python:    '#c55050',
  Perl:      '#a08060',
  JSON:      '#9fa8b0',
  Other:     'rgba(0,0,0,0.28)',
};
const colorFor = (name) => PALETTE[name] ?? '#6c757d';

const MATURITY_LABEL = {
  growing:   { text: 'growing',   color: '#4a9d5f' },
  plateau:   { text: 'plateau',   color: '#4f94d4' },
  declining: { text: 'declining', color: '#c58b2e' },
  mixed:     { text: 'mixed',     color: '#6c757d' },
};

// --- Streamgraph (inline SVG) -------------------------------------------
const SG_W = 880, SG_H = 180, SG_PAD_L = 16, SG_PAD_R = 16, SG_PAD_T = 10, SG_PAD_B = 22;
const SG_INNER_W = SG_W - SG_PAD_L - SG_PAD_R;
const SG_INNER_H = SG_H - SG_PAD_T - SG_PAD_B;

const dates = timeSeries.map(t => t.date);
const langKeys = languages.filter(l => l.name !== 'Other').map(l => l.name).concat(['Other']);

const xAt = (i) => SG_PAD_L + (i / Math.max(dates.length - 1, 1)) * SG_INNER_W;

const stacks = dates.map((_, i) => {
  const row = timeSeries[i];
  let acc = 0;
  const slices = {};
  for (const k of langKeys) {
    const v = row[k] ?? 0;
    slices[k] = { y0: acc, y1: acc + v };
    acc += v;
  }
  return { total: acc, slices };
});
const maxTotal = Math.max(...stacks.map(s => s.total));

const bandPath = (key) => {
  const up = stacks.map((s, i) => {
    const y = SG_PAD_T + (1 - s.slices[key].y1 / maxTotal) * SG_INNER_H;
    return `${i === 0 ? 'M' : 'L'} ${xAt(i).toFixed(1)} ${y.toFixed(1)}`;
  }).join(' ');
  const down = stacks.map((s, i) => {
    const y = SG_PAD_T + (1 - s.slices[key].y0 / maxTotal) * SG_INNER_H;
    return `L ${xAt(i).toFixed(1)} ${y.toFixed(1)}`;
  }).reverse().join(' ');
  return `${up} ${down} Z`;
};

// --- Sortable comparison table: pre-sort by commits desc --------------
const tableRows = [...languages].sort((a, b) => b.commits - a.commits);
const maxCommits = Math.max(...tableRows.map(r => r.commits));
const maxLines   = Math.max(...tableRows.map(r => r.linesAdded + r.linesRemoved));

function fmt(n) { return n.toLocaleString(); }
function pct(n, of) { return of ? `${((n / of) * 100).toFixed(1)}%` : '—'; }
function slug(name) { return name.toLowerCase().replace(/[^a-z0-9]+/g, '-'); }
---
<Base title="Languages · z-linux.com">
  <div class="shell">
    <header class="page-head">
      <div>
        <h1>Languages</h1>
        <p class="meta">predominant-language classification · {tableRows.length} languages · {fmt(total)} commits in {window.since} → {window.until}</p>
      </div>
      {_dummy && <span class="dummy-tag">dummy data</span>}
    </header>

    <section class="kpi-row">
      <div class="kpi">
        <div class="kpi-label">languages tracked</div>
        <div class="kpi-value">{tableRows.length}</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">dominant</div>
        <div class="kpi-value mono-sm">{dominant.name}</div>
        <div class="kpi-sub">{pct(dominant.commits, total)} of commits</div>
      </div>
      <div class="kpi" style="--band:#4a9d5f">
        <div class="kpi-label">fastest-growing</div>
        <div class="kpi-value mono-sm">{fastestGrowing?.name ?? '—'}</div>
        <div class="kpi-sub">
          {fastestGrowing ? `+${fastestGrowing.authorsGrowth30d} authors · +${fastestGrowing.fileCountGrowth30d} files (30d)` : '—'}
        </div>
      </div>
      <div class="kpi" style="--band:#ff7a5c">
        <div class="kpi-label">rust in-tree</div>
        <div class="kpi-value">{rustDays ? `${Math.floor(rustDays / 365)}y ${Math.floor((rustDays % 365) / 30)}m` : '—'}</div>
        <div class="kpi-sub">since {rust?.firstCommit ?? '—'}</div>
      </div>
    </section>

    <article class="card">
      <header class="card-head">
        <h2>Commits by language · over time</h2>
        <span class="head-sub">stacked · {window.since} → {window.until}</span>
      </header>
      <svg viewBox={`0 0 ${SG_W} ${SG_H}`} class="stream" preserveAspectRatio="none" role="img" aria-label="Stacked commits per language over time">
        {langKeys.map(k => (
          <path
            d={bandPath(k)}
            fill={colorFor(k)}
            opacity="0.88"
          >
            <title>{k}</title>
          </path>
        ))}
        {stacks.map((s, i) => (
          <text
            x={xAt(i)}
            y={SG_H - 6}
            text-anchor="middle"
            font-family="ui-monospace, SFMono-Regular, monospace"
            font-size="9"
            fill="rgba(0,0,0,0.45)"
          >{dates[i].slice(5)}</text>
        ))}
      </svg>
      <div class="legend">
        {langKeys.map(k => (
          <span>
            <span class="sq" style={`background:${colorFor(k)}`}></span>
            {k}
          </span>
        ))}
      </div>
    </article>

    <article class="card">
      <header class="card-head">
        <h2>Comparison</h2>
        <span class="head-sub">sorted by commits · click a row to drill</span>
      </header>
      <table class="lang-table">
        <thead>
          <tr>
            <th>Language</th>
            <th class="num">Commits</th>
            <th class="num">LOC +</th>
            <th class="num">LOC −</th>
            <th class="num">Authors</th>
            <th class="num">Files</th>
            <th class="num">Revert %</th>
            <th class="num">Fixes %</th>
            <th class="num">Churn Gini</th>
            <th class="num">CVEs</th>
            <th>Maturity</th>
            <th class="num">+A / +F (30d)</th>
          </tr>
        </thead>
        <tbody>
          {tableRows.map(l => {
            const m = MATURITY_LABEL[l.maturity] ?? MATURITY_LABEL.mixed;
            return (
              <tr>
                <td class="lang-name">
                  <a href={`/language/${slug(l.name)}/`}>
                    <span class="sq-inline" style={`background:${colorFor(l.name)}`}></span>
                    <span class="lname">{l.name}</span>
                  </a>
                </td>
                <td class="num">
                  <div class="barwrap">
                    <div class="bar-bg"></div>
                    <div class="bar-fill" style={`width:${(l.commits / maxCommits) * 100}%; background:${colorFor(l.name)}`}></div>
                    <span class="bar-num">{fmt(l.commits)}</span>
                  </div>
                </td>
                <td class="num mono">+{fmt(l.linesAdded)}</td>
                <td class="num mono muted">−{fmt(l.linesRemoved)}</td>
                <td class="num mono">{fmt(l.authors)}</td>
                <td class="num mono muted">{fmt(l.files)}</td>
                <td class="num mono">{(l.revertRate * 100).toFixed(2)}</td>
                <td class="num mono">{(l.fixesDensity * 100).toFixed(1)}</td>
                <td class="num mono">{l.churnConcentration.toFixed(2)}</td>
                <td class="num mono">{l.cveCount}</td>
                <td>
                  <span class="maturity-pill" style={`background:${m.color}22; color:${m.color}`}>{m.text}</span>
                </td>
                <td class="num mono growth">
                  <span class={l.authorsGrowth30d > 0 ? 'pos' : l.authorsGrowth30d < 0 ? 'neg' : 'zero'}>
                    {l.authorsGrowth30d > 0 ? '+' : ''}{l.authorsGrowth30d}
                  </span>
                  {' / '}
                  <span class={l.fileCountGrowth30d > 0 ? 'pos' : l.fileCountGrowth30d < 0 ? 'neg' : 'zero'}>
                    {l.fileCountGrowth30d > 0 ? '+' : ''}{l.fileCountGrowth30d}
                  </span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </article>
  </div>
</Base>

<style>
  .shell { max-width: 80rem; padding: 1.25rem 1.5rem 2.5rem; }
  .page-head {
    margin-bottom: 1.2rem;
    display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;
  }
  h1 {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 1.3rem; font-weight: 500; margin: 0;
  }
  .meta {
    margin: 0.2rem 0 0;
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.72rem; color: rgba(0,0,0,0.5);
  }
  .dummy-tag {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.62rem;
    padding: 0.15rem 0.45rem;
    background: rgba(197,139,46,0.13);
    color: #8b6620;
    border-radius: 3px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    align-self: center;
  }

  .kpi-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .kpi {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.9rem 1rem 0.95rem;
    display: flex; flex-direction: column; gap: 0.22rem;
    position: relative; overflow: hidden; min-width: 0;
  }
  .kpi::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px; background: var(--band, #4f94d4);
  }
  .kpi-label {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.66rem; text-transform: uppercase;
    letter-spacing: 0.12em; color: rgba(0,0,0,0.55);
  }
  .kpi-value {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 1.55rem; font-weight: 600; line-height: 1.08;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .kpi-value.mono-sm { font-size: 1.1rem; }
  .kpi-sub {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.72rem; color: rgba(0,0,0,0.55);
  }

  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.2rem 1.3rem;
    margin-bottom: 1rem;
  }
  .card-head {
    display: flex; align-items: baseline; justify-content: space-between; gap: 0.8rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .card h2 {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.74rem; font-weight: 500; margin: 0;
    color: var(--muted); text-transform: uppercase; letter-spacing: 0.12em;
  }
  .head-sub {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.7rem; color: rgba(0,0,0,0.45);
  }

  .stream { width: 100%; height: 200px; display: block; }

  .legend {
    display: flex; flex-wrap: wrap; gap: 0.5rem 1rem;
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.7rem; color: rgba(0,0,0,0.6);
    margin-top: 0.6rem;
  }
  .legend span { display: inline-flex; align-items: center; gap: 0.35rem; }
  .sq { width: 0.6rem; height: 0.6rem; border-radius: 1px; }

  .lang-table {
    width: 100%; border-collapse: collapse; font-size: 0.8rem;
  }
  .lang-table th {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.64rem; font-weight: 500;
    text-transform: uppercase; letter-spacing: 0.09em;
    color: rgba(0,0,0,0.45);
    text-align: left; white-space: nowrap;
    padding: 0.45rem 0.55rem 0.45rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .lang-table th.num, .lang-table td.num { text-align: right; }
  .lang-table td {
    padding: 0.5rem 0.55rem 0.5rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.04);
    vertical-align: middle;
  }
  .lang-table tr:last-child td { border-bottom: none; }
  .lang-table tbody tr:hover { background: rgba(79,148,212,0.04); cursor: pointer; }
  .lang-table .mono {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.78rem;
  }
  .lang-table .muted { color: rgba(0,0,0,0.55); }

  .lang-name a {
    display: inline-flex; align-items: center; gap: 0.45rem;
    color: inherit; text-decoration: none;
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.82rem; font-weight: 500;
  }
  .lang-name a:hover .lname {
    color: #2b5c8a;
    text-decoration: underline;
  }
  .sq-inline {
    width: 0.55rem; height: 0.55rem; border-radius: 1px;
    display: inline-block; flex-shrink: 0;
  }

  .barwrap {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.45rem;
    min-width: 7rem;
  }
  .bar-bg {
    height: 0.45rem; background: rgba(0,0,0,0.05); border-radius: 2px;
    grid-column: 1; grid-row: 1;
  }
  .bar-fill {
    height: 0.45rem;
    border-radius: 2px;
    grid-column: 1; grid-row: 1;
    opacity: 0.78;
  }
  .bar-num {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.78rem;
    grid-column: 2; grid-row: 1;
  }

  .maturity-pill {
    display: inline-block;
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.65rem;
    font-weight: 500;
    padding: 0.16rem 0.45rem;
    border-radius: 3px;
    letter-spacing: 0.05em;
    text-transform: lowercase;
  }
  .growth .pos  { color: #4a9d5f; }
  .growth .neg  { color: #e85b4a; }
  .growth .zero { color: rgba(0,0,0,0.4); }

  @media (max-width: 900px) {
    .kpi-row { grid-template-columns: repeat(2, 1fr); }
  }
</style>
